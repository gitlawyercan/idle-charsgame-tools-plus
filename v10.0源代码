function storageGet(key, fallback) { try { const r = localStorage.getItem(key); return r ? JSON.parse(r) : fallback; } catch { return fallback; } }
function storageSet(key, val) { try { localStorage.setItem(key, JSON.stringify(val)); } catch {} }

function getAllInventoryData() { return storageGet(SK.INVENTORY_DATA, {}); }
function saveCurrentInventory(email, name) { return (async()=>{const items=await parseInventory(); if(!Object.keys(items).length) return false; const d=getAllInventoryData(); d[email]={name,email,items,timestamp:Date.now()}; storageSet(SK.INVENTORY_DATA,d); return true;})(); }
function clearAllInventoryData() { localStorage.removeItem(SK.INVENTORY_DATA); updateStatus('🗑️ 背包数据已清除'); }
function getAggregatedInventory() { const d=getAllInventoryData(); const a={}; Object.values(d).forEach(e=>{if(e.items) Object.entries(e.items).forEach(([n,q])=>{a[n]=(a[n]||0)+q})}); return{a,rawData:d}; }

function getAllSkillData() { return storageGet(SK.SKILL_DATA, {}); }
function saveCurrentSkills(email, name) { return (async()=>{const skills=await parseSkills(); if(!Object.keys(skills).length) return false; const d=getAllSkillData(); d[email]={name,email,skills,timestamp:Date.now()}; storageSet(SK.SKILL_DATA,d); return true;})(); }
function clearAllSkillData() { localStorage.removeItem(SK.SKILL_DATA); updateStatus('🗑️ 技能数据已清除'); }
function getAggregatedSkills() { const d=getAllSkillData(); const em=Object.keys(d), sn=new Set(); Object.values(d).forEach(e=>{if(e.skills) Object.keys(e.skills).forEach(n=>sn.add(n))}); const sa={}, sav={}, sm={}; sn.forEach(n=>{const lv={}; let t=0,c=0,mx=0; em.forEach(e=>{const l=(d[e].skills&&d[e].skills[n])||0; lv[e]=l; if(l>0){t+=l;c++;mx=Math.max(mx,l)}}); sa[n]=lv; sav[n]=c>0?Math.round(t/c*10)/10:0; sm[n]=mx}); return{skillAccounts:sa,skillAvg:sav,skillMax:sm,rawData:d}; }

function getBuyOrders() { return storageGet(SK.BUY_ORDERS, {}); }
function saveBuyOrders(d) { storageSet(SK.BUY_ORDERS, d); }
function clearBuyOrders() { localStorage.removeItem(SK.BUY_ORDERS); localStorage.removeItem(SK.BUY_TIMER); }

