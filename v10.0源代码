let lastInvHash=0, lastSkillHash=0;
async function startRealtimeMonitor() {
    const la=loadLastAccount(); if(!la) return;
    setTimeout(async()=>{const items=await parseInventory(); if(Object.keys(items).length>0&&await saveCurrentInventory(la.email,la.name))lastInvHash=hashObject(items)},1500);
    setTimeout(async()=>{const skills=await parseSkills(); if(Object.keys(skills).length>0&&await saveCurrentSkills(la.email,la.name))lastSkillHash=hashObject(skills)},2000);
    setInterval(async()=>{const ca=loadLastAccount(); if(!ca)return; const items=await parseInventory(), ih=hashObject(items); if(ih!==lastInvHash&&Object.keys(items).length>0){lastInvHash=ih;await saveCurrentInventory(ca.email,ca.name)} const skills=await parseSkills(), sh=hashObject(skills); if(sh!==lastSkillHash&&Object.keys(skills).length>0){lastSkillHash=sh;await saveCurrentSkills(ca.email,ca.name)}},3600000);
}
