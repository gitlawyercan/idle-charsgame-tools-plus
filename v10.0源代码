function hashObject(obj) { const s=JSON.stringify(obj); let h=0; for(let i=0;i<s.length;i++){h=((h<<5)-h)+s.charCodeAt(i);h=h&h} return h; }
function getAccountGroupName(email) { const g=getAllAccountGroups(); for(const[gn,aa]of Object.entries(g)){if(aa.some(a=>a.email===email)) return gn} return'其他'; }
function downloadFile(c,f,m) { const b=new Blob([c],{type:m}),u=URL.createObjectURL(b),a=document.createElement('a'); a.href=u;a.download=f;a.click();URL.revokeObjectURL(u); }
function dateStr() { return new Date().toISOString().slice(0,10); }
function removeAllOverlays() { document.querySelectorAll('div[id^="stats-overlay-"]').forEach(el=>el.remove()); }
function sleep(ms) { return new Promise(r=>setTimeout(r,ms)); }

