// ★★★ API 函数 ★★★
// ============================================================
async function fetchAPI(url, body) {
    const token = getAuthToken();
    if (!token) return null;
    try {
        const r = await fetch(url, { method:'POST', headers:{'Content-Type':'application/json','Authorization':`Bearer ${token}`}, body:JSON.stringify(body||{}) });
        const d = await r.json();
        return d.code === 20000 ? d.data : null;
    } catch(e) { return null; }
}

async function fetchInventoryFromAPI() {
    const data = await fetchAPI(API.INVENTORY, {});
    if (!data) return {};
    const items = {};
    (data.inventory || []).forEach(item => { const n = ITEM_NAMES[item.itemId]; if (n) items[n] = (items[n]||0) + item.qty; });
    return items;
}

async function fetchProfileFromAPI() {
    const data = await fetchAPI(API.PROFILE, {});
    if (!data?.player) return {skills:{}, gold:0, diamonds:0, totalLevel:0, combatLevel:0, playerName:''};
    const p = data.player, skills = {};
    (p.actionSkills||[]).forEach(s => { const n = SKILL_NAMES[s.actionSkillId]; if (n) skills[n] = s.level; });
    return {skills, gold:p.gold||0, diamonds:p.diamonds||0, totalLevel:p.totalLevel||0, combatLevel:p.combatLevel||0, playerName:p.name||''};
}

// ============================================================
// ★★★ 背包解析 ★★★
// ============================================================
async function parseInventory() {
    const api = await fetchInventoryFromAPI();
    if (Object.keys(api).length > 0) return api;
    const items = {}, grid = document.querySelector('.inventory-grid');
    if (!grid) return items;
    grid.querySelectorAll('.inventory-item-tooltip').forEach(el => {
        const btn = el.querySelector('button');
        if (!btn) return;
        const label = btn.getAttribute('aria-label')||'', m = label.match(/^(.+?)，数量\s*(\d+)$/);
        if (m) { const n=m[1].trim(), q=parseInt(m[2])||0; items[n]=(items[n]||0)+q; }
        else { const qs = btn.querySelector('.inventory-item-quantity'); if (qs) { const n2=label.split(/[，,]/)[0].trim()||'未知'; items[n2]=(items[n2]||0)+(parseInt(qs.textContent.trim())||1); } }
    });
    return items;
}

async function parseSkills() {
    const p = await fetchProfileFromAPI();
    if (Object.keys(p.skills).length > 0) return p.skills;
    const skills = {};
    document.querySelectorAll('.flex-1.py-2 section.py-2').forEach(sec => {
        sec.querySelectorAll('a').forEach(link => {
            const ne = link.querySelector('.flex-1.text-left');
            if (!ne) return;
            const n = ne.textContent.trim(); if (!n) return;
            const ls = link.querySelector('.tabular-nums');
            skills[n] = ls ? parseInt(ls.textContent.trim())||0 : 0;
        });
    });
    return skills;
}

