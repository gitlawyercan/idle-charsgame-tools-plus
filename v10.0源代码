async function startBuyCrawl(isAuto) {
    if (buyCrawling) { alert('⚠️ 正在采集中，请稍候'); return; }
    buyCrawling = true; setBuyStatus('🔄 开始采集...');
    for (const id of MARKET_ITEM_IDS) {
        const d = getBuyOrders();
        if (d[id] && d[id].timestamp) continue;
        const name = ITEM_NAMES[id] || '未知';
        setBuyStatus(`🔄 采集 ID=${id} (${name}) ...`);
        const token = getAuthToken();
        if (!token) { setBuyStatus('❌ 未找到 token'); buyCrawling = false; return; }
        try {
            const r = await fetch(API.MARKET_ORDER_BOOK, { method:'POST', headers:{'Content-Type':'application/json','Authorization':`Bearer ${token}`}, body:JSON.stringify({itemId:id}) });
            const j = await r.json();
            if (j.code === 20000) {
                const orders = (j.data?.buyOrders||[]).map((o,i)=>({index:i+1, itemName:name, price:String(o.price||0), quantity:String(o.qty||o.quantity||0)}));
                const allData = getBuyOrders(); allData[id] = { itemId: id, itemName: name, buyOrders: orders, timestamp: Date.now() };
                saveBuyOrders(allData); renderBuyOrders(); updateBuyStats();
                setBuyStatus(`✅ ${name} (${orders.length} 条买单)`);
            } else setBuyStatus(`❌ ${name}: ${j.message}`);
        } catch(e) { setBuyStatus(`❌ ${name}: ${e.message}`); }
        await sleep(1200);
    }
    const d = getBuyOrders(), wd = Object.values(d).filter(r => r.buyOrders && r.buyOrders.length > 0).length;
    setBuyStatus(`🎉 采集完成！共 ${Object.keys(d).length} 个 (${wd} 个有数据)`);
    buyCrawling = false;
}

